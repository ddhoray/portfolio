# === DATABASE ===
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://your_user:your_password@your_host:5432/your_database"

# === ABACUS.AI EMAIL NOTIFICATIONS ===
# Used by the contact form to send email notifications
# If migrating to a different email service, these can be removed
ABACUSAI_API_KEY=your_abacus_api_key
WEB_APP_ID=your_web_app_id
NOTIF_ID_PROFESSIONAL_CONTACT_FORM=your_professional_notif_id
NOTIF_ID_CYBERSAFETT_CONTACT_FORM=your_cybersafett_notif_id

# === APPLICATION ===
NODE_ENV=production
PORT=3000
